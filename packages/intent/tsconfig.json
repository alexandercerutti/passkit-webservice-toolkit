{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"target": "ES2018",
		"module": "CommonJS",
		"moduleResolution": "Node10",
		"outDir": "./lib",
		// To ignore Node10 deprecation. When it will be removed, we'll remove
		// The whole CJS compilation target
		"ignoreDeprecations": "6.0",
		"rootDir": "./src",
		/**
		 * This is required for service injection inside controller.
		 * This is also already available in the sample-app when it gets
		 * created
		 */
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"composite": true
	},
	"include": ["./src/**/*"],
	"references": [{ "path": "../toolkit/tsconfig.json" }]
}
